# =============================================================================
# Aletheia - Development Environment Variables
# =============================================================================
# Copy this file to .env and customize for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Django Configuration
# -----------------------------------------------------------------------------

# Environment (development/production/testing)
ALETHEIA_ENVIRONMENT=development

# Security - Generate a new key with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production

# Debug mode (NEVER enable in production)
DEBUG=true

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection (production)
DATABASE_URL=postgres://aletheia:password@localhost:5432/aletheia

# Or individual settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=aletheia
DB_USER=aletheia
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# SQLite (development fallback)
# DATABASE_URL=sqlite:///db.sqlite3

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis URL for caching and Celery
REDIS_URL=redis://localhost:6379/0

# Separate databases for different purposes
REDIS_CACHE_DB=0
REDIS_CELERY_DB=1
REDIS_SESSION_DB=2

# -----------------------------------------------------------------------------
# Celery Configuration
# -----------------------------------------------------------------------------

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Task settings
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT=600
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------

# Local storage
MEDIA_ROOT=/path/to/media
STATIC_ROOT=/path/to/static

# S3 storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=aletheia-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# ML Configuration
# -----------------------------------------------------------------------------

# Model paths
MODEL_CHECKPOINT_PATH=/path/to/models

# Device selection (cuda/cpu/auto)
ML_DEVICE=auto

# Precision (fp32/fp16/bf16/auto)
ML_PRECISION=auto

# Batch size for inference
ML_BATCH_SIZE=8

# Number of worker threads
ML_NUM_WORKERS=4

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=15  # minutes
JWT_REFRESH_TOKEN_LIFETIME=7  # days

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------

# Sentry DSN (optional)
SENTRY_DSN=

# Log level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Structured logging (json/console)
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@aletheia.ai

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# OpenAI API (for future LLM features)
OPENAI_API_KEY=

# Google Cloud (for advanced face detection)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

FEATURE_ENABLE_REGISTRATION=true
FEATURE_ENABLE_API_KEYS=true
FEATURE_ENABLE_WEBHOOKS=true
FEATURE_ENABLE_BATCH_PROCESSING=true
FEATURE_ENABLE_ADVANCED_MODELS=true
