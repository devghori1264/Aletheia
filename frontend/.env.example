# Aletheia Frontend Environment Variables

# API Configuration
# Use relative path for development (Vite proxy forwards to backend)
# Use full URL for production or when not using Vite dev server
VITE_API_URL=/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# Feature Flags
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_ANALYTICS=false

# Build Information
VITE_APP_VERSION=1.0.0
